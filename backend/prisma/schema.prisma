generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String @id @default(uuid())
  email         String @unique
  password_hash String
  role          String @default("admin")

  @@map("users")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  slug          String?  @unique
  description   String?
  story         String?
  materials     String?
  dimensions    String?
  price         Float
  category_id   String?
  main_image    String?
  featured      Boolean  @default(false)
  status        String?
  availability  String?
  collection_id String?
  created_at    DateTime @default(now())

  category   Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  collection Collection? @relation(fields: [collection_id], references: [id], onDelete: SetNull)
  
  images             ProductImage[]
  collectionProducts CollectionProduct[]
  lookbookProducts   LookbookProduct[]

  @@map("products")
}

model ProductImage {
  id         String  @id @default(uuid())
  product_id String?
  image_url  String
  sort_order Int     @default(0)

  product Product? @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Collection {
  id                String   @id @default(uuid())
  name              String
  slug              String?  @unique
  short_description String?
  story             String?
  cover_image       String?
  hero_image        String?
  season            String?
  theme             String?
  status            String?
  featured          Boolean?
  created_at        DateTime @default(now())

  products           Product[]
  media              Media[]
  collectionProducts CollectionProduct[]

  @@map("collections")
}

model CollectionProduct {
  id            String  @id @default(uuid())
  collection_id String?
  product_id    String?

  collection Collection? @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  product    Product?    @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("collection_products")
}

model Media {
  id            String  @id @default(uuid())
  url           String
  caption       String?
  type          String?
  collection_id String?

  collection Collection? @relation(fields: [collection_id], references: [id], onDelete: Cascade)

  @@map("media")
}

model Lookbook {
  id           String    @id @default(uuid())
  title        String
  slug         String?   @unique
  description  String?
  story        String?
  cover_image  String?
  status       String?   @default("Draft")
  published_at DateTime?
  created_at   DateTime  @default(now())

  images   LookbookImage[]
  products LookbookProduct[]

  @@map("lookbooks")
}

model LookbookImage {
  id          String  @id @default(uuid())
  lookbook_id String?
  image_url   String
  caption     String?
  sort_order  Int     @default(0)

  lookbook Lookbook? @relation(fields: [lookbook_id], references: [id], onDelete: Cascade)

  @@map("lookbook_images")
}

model LookbookProduct {
  id          String  @id @default(uuid())
  lookbook_id String?
  product_id  String?

  lookbook Lookbook? @relation(fields: [lookbook_id], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("lookbook_products")
}
